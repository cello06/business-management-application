{
  "_version": "1.53.0",
  "sap.app": {
    "id": "hrproject",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.3",
      "toolsId": "15a24349-961e-4ff7-ad77-389309f412ee"
    },
    "dataSources": {
      "ZUI_HR_V2_BIND_VAN": {
        "uri": "/sap/opu/odata/IWFND/CATALOGSERVICE;v=2/Annotations(TechnicalName='ZUI_HR_V2_BIND_VAN',Version='0001')/$value/",
        "type": "ODataAnnotation",
        "settings": {
          "localUri": "localService/mainService/ZUI_HR_V2_BIND_VAN.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZUI_HR_V2_BIND/",
        "type": "OData",
        "settings": {
          "annotations": [
            "ZUI_HR_V2_BIND_VAN"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "department-manage": {
          "semanticObject": "department",
          "action": "manage",
          "title": "{{department-manage.flpTitle}}",
          "subTitle": "{{department-manage.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.114.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {},
        "sap.suite.ui.microchart": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "hrproject.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "hrproject.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": "",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "RouteSectors",
          "pattern": "sectors",
          "target": [
            "TargetSectors"
          ]
        },
        {
          "name": "RouteCourseDetail",
          "pattern": "courseDetail/{sectorId}/{persId}/{courseId}",
          "target": "TargetCourseDetail"
        },
        {
          "name": "RouteProjectDetail",
          "pattern": "projectDetail/{sectorId}/{persId}/{projectId}",
          "target": "TargetProjectDetail"
        },
        {
          "name": "RouteEmployee",
          "pattern": "employees/{sectorId}",
          "target": [
            "TargetEmployee"
          ]
        },
        {
          "name": "RouteEmployeeDetail",
          "pattern": "employee/{sectorId}/{persId}",
          "target": "TargetEmployeeDetail"
        },
        {
          "name": "RouteMyCourses",
          "pattern": "myCourses/{persId}",
          "target": "TargetMyCourses"
        },
        {
          "name": "RouteCourseList",
          "pattern": "courseList/{type}/{persId}",
          "target": "TargetCourseList"
        },
        {
          "name": "RouteCreateEmployee",
          "pattern": "employeeCreate/{sectorId}",
          "target": "TargetCreateEmployee"
        },
        {
          "pattern": "assignCourse/{sectorId}/{persId}",
          "name": "RouteAssignCourse",
          "target": "TargetAssignCourse"
        },
        {
          "name": "RouteAssignProject",
          "pattern": "assignProject/{sectorId}/{persId}",
          "target": "TargetAssignProject"
        }
      ],
      "targets": {
        "TargetHome": {
          "viewType": "XML",
          "transition": "slide",
          "viewId": "Home",
          "viewName": "Home"
        },
        "TargetSectors": {
          "viewType": "XML",
          "transition": "slide",
          "viewId": "Sectors",
          "viewName": "Sectors"
        },
        "TargetProjectDetail": {
          "viewType": "XML",
          "viewId": "ProjectDetail",
          "viewName": "employeeDetail.ProjectDetail"
        },
        "TargetMyCourses": {
          "viewType": "XML",
          "transition": "slide",
          "viewId": "MyCourses",
          "viewName": "myCourses.MyCourses"
        },
        "TargetCourseList": {
          "viewType": "XML",
          "transition": "slide",
          "viewId": "CourseList",
          "viewName": "myCourses.CourseList"
        },
        "TargetEmployee": {
          "viewType": "XML",
          "transition": "slide",
          "viewId": "Employee",
          "viewName": "Employee"
        },
        "TargetEmployeeDetail": {
          "viewType": "XML",
          "viewId": "EmployeeDetail",
          "viewName": "EmployeeDetail"
        },
        "TargetCreateEmployee": {
          "viewType": "XML",
          "viewId": "CreateEmployee",
          "viewName": "CreateEmployee"
        },
        "TargetCourseDetail": {
          "viewType": "XML",
          "viewId": "CourseDetail",
          "viewName": "employeeDetail.CourseDetail"
        },
        "TargetAssignCourse": {
          "viewType": "XML",
          "viewName": "employeeDetail.AssignCourse",
          "viewId": "AssignCourse",
          "controlId": "app",
          "controlAggregation": "pages"
        },
        "TargetAssignProject": {
          "viewType": "XML",
          "viewId": "AssignProject",
          "viewName": "employeeDetail.AssignProject",
          "controlId": "app",
          "controlAggregation": "pages"
        }
      }
    },
    "rootView": {
      "viewName": "hrproject.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  }
}