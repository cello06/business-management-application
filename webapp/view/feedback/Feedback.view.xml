<mvc:View
    controllerName="hrproject.controller.feedback.Feedback"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified"
    xmlns:form="sap.ui.layout.form">

    <Page
        id="feedbackPage"
        title="Send Feedback"
        showNavButton="true"
        navButtonPress=".onNavBack"
        busy="{feedback>/busy}"
        busyIndicatorDelay="0">

        <content>
            <l:VerticalLayout width="100%" class="sapUiMediumMargin">

                <MessageStrip
                    text="Tell us what's wrong or what you'd like to see. Your message will be sent with your user id and the current timestamp."
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginBottom"/>

                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="1" emptySpanL="1" emptySpanM="1" emptySpanS="0"
                    columnsXL="1" columnsL="1" columnsM="1"
                    singleContainerFullSize="false">

                    <form:content>

                        <Label text="Type" required="true"/>
                        <Select
                            selectedKey="{feedback>/type}"
                            width="320px">
                            <core:Item key="BUG"     text="Bug Report"/>
                            <core:Item key="FEATURE" text="Feature Request"/>
                            <core:Item key="GENERAL" text="General Feedback"/>
                        </Select>

                        <Label text="Subject" required="true"/>
                        <Input
                            value="{feedback>/subject}"
                            maxLength="100"
                            placeholder="Short summary"
                            width="100%"/>

                        <Label text="Description" required="true"/>
                        <TextArea
                            id="descArea"
                            value="{feedback>/description}"
                            maxLength="1000"
                            rows="10"
                            growing="true"
                            growingMaxLines="20"
                            width="100%"
                            placeholder="Steps to reproduce, expected vs actual — paste screenshots with Ctrl+V"/>

                        <Label text="Attachments"/>
                        <l:VerticalLayout width="100%">
                            <u:FileUploader
                                id="feedbackUploader"
                                name="feedbackFile"
                                multiple="true"
                                buttonText="Add files"
                                placeholder="Select images or PDF..."
                                mimeType="image/png,image/jpeg,image/gif,application/pdf"
                                sameFilenameAllowed="true"
                                change=".onFilesSelected"
                                typeMissmatch=".onTypeMismatch"
                                width="100%"/>
                            <List
                                items="{feedback>/attachments}"
                                visible="{= ${feedback>/attachments}.length > 0 }"
                                class="sapUiSmallMarginTop">
                                <StandardListItem
                                    title="{feedback>fileName}"
                                    description="{feedback>mimeType}"
                                    info="{feedback>sizeText}"
                                    icon="sap-icon://attachment"
                                    type="Active"
                                    press=".onRemoveAttachment"/>
                            </List>
                            <Text
                                text="Tap an attachment to remove it."
                                visible="{= ${feedback>/attachments}.length > 0 }"
                                class="sapUiTinyMarginTop"/>
                        </l:VerticalLayout>

                    </form:content>
                </form:SimpleForm>

            </l:VerticalLayout>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button
                    text="Submit"
                    type="Emphasized"
                    icon="sap-icon://paper-plane"
                    press=".onSubmit"/>
                <Button
                    text="Cancel"
                    press=".onCancel"/>
            </OverflowToolbar>
        </footer>

    </Page>
</mvc:View>
