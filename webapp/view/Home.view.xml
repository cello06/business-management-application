<mvc:View
    controllerName="hrproject.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
>
    <Page showHeader="false">

        <l:BlockLayout background="Default">

            <!-- ═══ ROW 1 — Hero Image ═══════════════════════ -->
            <l:BlockLayoutRow>
                <l:BlockLayoutCell class="hrHeroImageCell sapUiNoContentPadding">
                    <Image
                        src="/sap/bc/ui5_ui5/sap/zui5_hr_project/img/hero.jpg"
                        width="100%"
                        densityAware="false"
                        decorative="true"
                        class="hrHeroImage"
                    />
                </l:BlockLayoutCell>
            </l:BlockLayoutRow>

            <!-- ═══ ROW 2 — ADMIN tiles ══════════════════════ -->
            <l:BlockLayoutRow visible="{= ${home>/roleLoaded} &amp;&amp; ${home>/isAdmin} }">

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeD" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="Sectors"
                        subheader="Browse departments"
                        frameType="TwoByOne"
                        press=".onOpenSectors">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://organization-chart" size="2rem" color="Default"/>
                                        <NumericContent value="{home>/sectorCount}" indicator="None" withMargin="false"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeB" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="Create Department"
                        subheader="Add a new sector"
                        frameType="TwoByOne"
                        press=".onCreateDepartment">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://add" size="2rem" color="Default"/>
                                        <Text text="Create a new department" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeD" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="Employee Registration"
                        subheader="Register a new employee"
                        frameType="TwoByOne"
                        press=".onEmployeeRegistration">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://add-employee" size="2rem" color="Default"/>
                                        <Text text="Register employees" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeB" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="Course Registration"
                        subheader="Assign courses"
                        frameType="TwoByOne"
                        press=".onCourseRegistration">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://course-book" size="2rem" color="Default"/>
                                        <Text text="Assign training courses" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

            </l:BlockLayoutRow>

            <!-- ═══ ROW 2 — EMPLOYEE tiles (all 5 in one row) ══ -->
            <l:BlockLayoutRow visible="{= ${home>/roleLoaded} &amp;&amp; !${home>/isAdmin} }">

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeD" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="My Courses"
                        subheader="View assigned courses"
                        frameType="TwoByOne"
                        press=".onMyCourses">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://education" size="2rem" color="Default"/>
                                        <Text text="Track your training" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeB" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="My Projects"
                        subheader="View assigned projects"
                        frameType="TwoByOne"
                        press=".onMyProjects">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://project-definition-triangle" size="2rem" color="Default"/>
                                        <Text text="See your active projects" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeD" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="Daily Activities"
                        subheader="Track your day"
                        frameType="TwoByOne"
                        press=".onDailyActivities">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://activity-items" size="2rem" color="Default"/>
                                        <Text text="Log daily work" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeB" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="My Calendar"
                        subheader="Your schedule"
                        frameType="TwoByOne"
                        press=".onMyCalendar">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://appointment-2" size="2rem" color="Default"/>
                                        <Text text="Plan your appointments" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

                <l:BlockLayoutCell backgroundColorSet="ColorSet11" backgroundColorShade="ShadeD" class="hrFeatureCell">
                    <GenericTile
                        class="hrBlockTile"
                        header="My Profile"
                        subheader="View your details"
                        frameType="TwoByOne"
                        press=".onMyProfile">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <l:VerticalLayout>
                                        <core:Icon src="sap-icon://employee" size="2rem" color="Default"/>
                                        <Text text="Personal information" class="sapUiSmallMarginTop"/>
                                    </l:VerticalLayout>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </l:BlockLayoutCell>

            </l:BlockLayoutRow>

            <!-- ═══ ROW 3 — Welcome message ══════════════════ -->
            <l:BlockLayoutRow visible="{home>/roleLoaded}">
                <l:BlockLayoutCell
                    backgroundColorSet="ColorSet11"
                    backgroundColorShade="ShadeB"
                    class="hrFeatureCell">
                    <l:VerticalLayout width="100%">
                        <core:Icon src="sap-icon://hr-approval" size="3rem" color="Default" class="sapUiTinyMarginBottom"/>
                        <Title
                            text="Welcome to Company Business Management Site"
                            level="H2"
                            titleStyle="H3"
                            class="sapUiTinyMarginTopBottom"
                        />
                        <Text text="Manage departments, employees and courses from a single place. Use the tiles above to navigate to the area you need."/>
                    </l:VerticalLayout>
                </l:BlockLayoutCell>
            </l:BlockLayoutRow>

        </l:BlockLayout>

    </Page>
</mvc:View>