<mvc:View
    controllerName="hrproject.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
>
    <Page title="Company Business Management Site">
        <content>
            <VBox class="sapUiMediumMargin">
                <f:Card class="homeHeroCard">
                    <f:content>
                        <VBox class="sapUiSmallMargin" width="100%">
                            <VBox
                                class="homeHeroContentBox"
                                width="100%"
                                alignItems="Center"
                                justifyContent="Center"
                            >
                                <VBox class="homeHeroTextBox" width="100%">
                                    <Title
                                        text="Company Business Management Site"
                                        level="H1"
                                        class="homeHeroTitle"
                                    />
                                    <Text
                                        text="Manage departments, employees and courses from a single place."
                                        class="homeHeroSubtitle sapUiSmallMarginBottom"
                                    />
                                </VBox>

                                <VBox
                                    width="100%"
                                    alignItems="Center"
                                    justifyContent="Center"
                                    class="homeHeroCarouselBox sapUiSmallMarginTop"
                                >
                                    <Carousel
                                        id="heroCarousel"
                                        height="340px"
                                        loop="true"
                                        showPageIndicator="true"
                                        pageIndicatorPlacement="Bottom"
                                        class="homeHeroCarousel"
                                    >
                                        <Image
                                            src="img/hero.jpg"
                                            width="100%"
                                            height="100%"
                                            decorative="true"
                                            class="homeHeroSlideImg"
                                        />
                                        <Image
                                            src="img/hero2.jpg"
                                            width="100%"
                                            height="100%"
                                            decorative="true"
                                            class="homeHeroSlideImg"
                                        />
                                        <Image
                                            src="img/hero3.jpg"
                                            width="100%"
                                            height="100%"
                                            decorative="true"
                                            class="homeHeroSlideImg"
                                        />
                                        <Image
                                            src="img/hero4.jpg"
                                            width="100%"
                                            height="100%"
                                            decorative="true"
                                            class="homeHeroSlideImg"
                                        />
                                    </Carousel>
                                </VBox>
                            </VBox>
                        </VBox>
                    </f:content>
                </f:Card>
            </VBox>

            <VBox class="sapUiMediumMargin">
                <Title
                    text="Quick Actions"
                    level="H2"
                    class="sapUiSmallMarginBottom"
                />

                <f:GridContainer
                    containerQuery="true"
                    class="homeActionsGrid"
                >
                    <f:layout>
                        <f:GridContainerSettings
                            rowSize="10rem"
                            columnSize="12rem"
                            gap="1rem"
                        />
                    </f:layout>

                    <f:items>
                        <GenericTile
                            class="sectorTile homeActionTile"
                            header="Sectors"
                            subheader="Browse departments"
                            headerImage="sap-icon://organization-chart"
                            frameType="TwoByOne"
                            press=".onOpenSectors"
                        >
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1" />
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent
                                            value="{home>/sectorCount}"
                                            indicator="None"
                                            withMargin="false"
                                        />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <GenericTile
                            class="sectorTile homeActionTile"
                            header="Create Department"
                            subheader="Add a new sector"
                            headerImage="sap-icon://add"
                            frameType="TwoByOne"
                            press=".onCreateDepartment"
                        >
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1" />
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <Text text="Create" />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <GenericTile
                            class="sectorTile homeActionTile"
                            header="Employee Registration"
                            subheader="Register a new employee"
                            headerImage="sap-icon://add-employee"
                            frameType="TwoByOne"
                            press=".onEmployeeRegistration"
                        >
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1" />
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <Text text="Register" />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <GenericTile
                            class="sectorTile homeActionTile"
                            header="Course Registration"
                            subheader="Assign courses"
                            headerImage="sap-icon://course-book"
                            frameType="TwoByOne"
                            press=".onCourseRegistration"
                        >
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1" />
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <Text text="Assign" />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>
                    </f:items>
                </f:GridContainer>
            </VBox>
        </content>
    </Page>
</mvc:View>