<mvc:View
    controllerName="hrproject.controller.myProjects.MyProjects"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
>
    <Page title="My Projects" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <VBox class="sapUiMediumMargin">
                <Title text="My Projects" level="H2" class="sapUiSmallMarginBottom"/>

                <f:GridContainer containerQuery="true" class="homeActionsGrid">
                    <f:layout>
                        <f:GridContainerSettings rowSize="10rem" columnSize="12rem" gap="1rem"/>
                    </f:layout>
                    <f:items>

                        <GenericTile
                            class="homeActionTile"
                            header="Ongoing"
                            subheader="Active projects"
                            headerImage="sap-icon://status-in-process"
                            frameType="TwoByOne"
                            press=".onTilePress"
                        >
                            <customData>
                                <core:CustomData key="type" value="ongoing"/>
                            </customData>
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1"/>
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent value="{myProjects>/ongoingCount}" indicator="None" withMargin="false"/>
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <GenericTile
                            class="homeActionTile"
                            header="Finished"
                            subheader="Completed projects"
                            headerImage="sap-icon://sys-enter-2"
                            frameType="TwoByOne"
                            press=".onTilePress"
                        >
                            <customData>
                                <core:CustomData key="type" value="finished"/>
                            </customData>
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1"/>
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent value="{myProjects>/finishedCount}" indicator="None" withMargin="false"/>
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <GenericTile
                            class="homeActionTile"
                            header="All Projects"
                            subheader="Browse all company projects"
                            headerImage="sap-icon://project-definition-triangle"
                            frameType="TwoByOne"
                            press=".onTilePress"
                        >
                            <customData>
                                <core:CustomData key="type" value="all"/>
                            </customData>
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1"/>
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent value="{myProjects>/allCount}" indicator="None" withMargin="false"/>
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                    </f:items>
                </f:GridContainer>
            </VBox>
        </content>
    </Page>
</mvc:View>