<mvc:View
    controllerName="hrproject.controller.employeeDetail.CompletedCoursesDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox width="100%" fitContainer="true" renderType="Bare">
        <Toolbar width="100%">
            <Title text="Completed Courses" level="H3" />
            <ToolbarSpacer />
            <Button text="Export" press=".onExportPress" />
        </Toolbar>

        <List
            id="completedCoursesList"
            width="100%"
            items="{courses>/completed}"
            noDataText="No completed courses found"
            mode="None"
            itemPress=".onCoursePress">

            <ObjectListItem
                type="Navigation"
                title="{courses>CourseName}"
                intro="Completed"
                number="{courses>CourseId}"
                numberUnit="ID">

                <attributes>
                    <ObjectAttribute text="{= 'Completed Hours: ' + (${courses>CompletedHours} || 0) + ' / ' + (${courses>TotalHours} || 0) }" />
                    <ObjectAttribute text="{courses>Category}" />
                </attributes>

            </ObjectListItem>
        </List>
    </VBox>
</mvc:View>