<mvc:View
    controllerName="hrproject.controller.employeeDetail.AssignedProjectsDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox width="100%" fitContainer="true" renderType="Bare">
        <Toolbar width="100%">
            <Title text="Assigned Projects" level="H3" />
            <ToolbarSpacer />
            <Button
                text="Assign"
                type="Emphasized"
                press=".onAssignProjectPress"
                class="sapUiTinyMarginEnd" />
            <Button
                text="Refresh"
                press=".onRefreshPress" />
        </Toolbar>

        <List
            id="assignedProjectsList"
            width="100%"
            items="{projects>/items}"
            noDataText="No assigned projects found"
            mode="None"
            itemPress=".onProjectPress">

            <ObjectListItem
                type="Navigation"
                title="{projects>ProjectName}"
                number="{projects>ProjectId}"
                numberUnit="ID">
                <attributes>
                    <ObjectAttribute text="{= 'Role: ' + (${projects>Role} || '') }" />
                    <ObjectAttribute text="{= 'Priority: ' + (${projects>Priority} || '') }" />
                    <ObjectAttribute text="{= 'Hours: ' + (${projects>CompletedHours} || 0) + ' / ' + (${projects>TotalHours} || 0) }" />
                </attributes>
                <firstStatus>
                    <ObjectStatus text="{projects>StatusText}" state="{projects>StatusState}" />
                </firstStatus>
            </ObjectListItem>
        </List>
    </VBox>
</mvc:View>