<mvc:View
    controllerName="hrproject.controller.employeeDetail.OngoingCoursesDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    
    <VBox width="100%" fitContainer="true" renderType="Bare">
        <Toolbar width="100%">
            <Title text="Ongoing Courses" level="H3" />
            <ToolbarSpacer />
            <Button text="Add Course" type="Emphasized" press=".onAddCoursePress" />
            <Button text="Refresh" press=".onRefreshPress" />
        </Toolbar>

        <List
            id="ongoingCoursesList"
            width="100%"
            items="{courses>/ongoing}"
            noDataText="No ongoing courses found"
            mode="None"
            itemPress=".onCoursePress">

            <ObjectListItem
                type="Navigation"
                title="{courses>CourseName}"
                
                number="{courses>CourseId}"
                numberUnit="ID">

                <attributes>
                    <ObjectAttribute text="{= 'Completed Hours: ' + (${courses>CompletedHours} || 0) + ' / ' + (${courses>TotalHours} || 0) }" />
                    <ObjectAttribute text="{courses>Category}" />
                </attributes>

            </ObjectListItem>
        </List>
    </VBox>
</mvc:View>