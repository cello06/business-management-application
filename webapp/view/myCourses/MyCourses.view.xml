<mvc:View
    controllerName="hrproject.controller.myCourses.MyCourses"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
>
    <Page
        title="My Courses"
        showNavButton="true"
        navButtonPress=".onNavBack"
    >
        <content>
            <VBox class="sapUiMediumMargin">

                <Title
                    text="My Courses"
                    level="H2"
                    class="sapUiSmallMarginBottom"
                />

                <f:GridContainer containerQuery="true" class="homeActionsGrid">
                    <f:layout>
                        <f:GridContainerSettings
                            rowSize="10rem"
                            columnSize="12rem"
                            gap="1rem"
                        />
                    </f:layout>
                    <f:items>

                        <GenericTile
                            class="homeActionTile"
                            header="Ongoing"
                            subheader="Active courses"
                            headerImage="sap-icon://course-book"
                            frameType="TwoByOne"
                            press=".onTilePress"
                        >
                            <customData>
                                <core:CustomData key="type" value="ongoing"/>
                            </customData>
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1"/>
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent
                                            value="{myCourses>/ongoingCount}"
                                            indicator="None"
                                            withMargin="false"
                                        />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <GenericTile
                            class="homeActionTile"
                            header="Finished"
                            subheader="Completed courses"
                            headerImage="sap-icon://accept"
                            frameType="TwoByOne"
                            press=".onTilePress"
                        >
                            <customData>
                                <core:CustomData key="type" value="finished"/>
                            </customData>
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1"/>
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent
                                            value="{myCourses>/finishedCount}"
                                            indicator="None"
                                            withMargin="false"
                                        />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <GenericTile
                            class="homeActionTile"
                            header="All Courses"
                            subheader="Browse all courses"
                            headerImage="sap-icon://learning-assistant"
                            frameType="TwoByOne"
                            press=".onTilePress"
                        >
                            <customData>
                                <core:CustomData key="type" value="all"/>
                            </customData>
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1"/>
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent
                                            value="{myCourses>/allCount}"
                                            indicator="None"
                                            withMargin="false"
                                        />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                        <!-- Certificates tile (coming soon) -->
                        <GenericTile
                            class="homeActionTile"
                            header="Certificates"
                            subheader="Your achievements"
                            headerImage="sap-icon://badge"
                            frameType="TwoByOne"
                            press=".onCertificatesPress"
                        >
                            <layoutData>
                                <f:GridContainerItemLayoutData columns="2" rows="1"/>
                            </layoutData>
                            <tileContent>
                                <TileContent>
                                    <content>
                                        <NumericContent
                                            value="{myCourses>/finishedCount}"
                                            indicator="None"
                                            withMargin="false"
                                        />
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>

                    </f:items>
                </f:GridContainer>
            </VBox>
        </content>
    </Page>
</mvc:View>