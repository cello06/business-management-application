<mvc:View
    controllerName="hrproject.controller.EmployeeDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:layout="sap.ui.layout">

    <Page
        title="Employee Detail"
        showNavButton="true"
        navButtonPress=".onNavBack">

      

        <content>
            <VBox class="sapUiSmallMargin" width="100%">
                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                    <Avatar
                        src="{= ${PhotoUrl} ? 'data:image/jpeg;base64,' + ${PhotoUrl} : '' }"
                        initials="{= (${FirstName} || '?').charAt(0) + (${LastName} || '').charAt(0) }"
                        displayShape="Circle"
                        displaySize="L"
                        class="sapUiSmallMarginEnd" />
                    <VBox>
                        <Title text="{FirstName} {LastName}" level="H3" />
                        <Text text="{Title}" />
                        <ObjectStatus
                            text="{Status}"
                            state="{= ${Status} === 'ACTIVE' ? 'Success' : 'Warning' }" />
                    </VBox>
                </HBox>

                <f:SimpleForm
                    editable="false"
                    layout="ResponsiveGridLayout"
                    title="Personal Information"
                    class="sapUiSmallMarginBottom">

                    <Label text="Person ID" />
                    <Text text="{path: 'PersId', formatter: '.formatter.maskTcId'}" />

                    <Label text="First Name" />
                    <Text text="{FirstName}" />

                    <Label text="Last Name" />
                    <Text text="{LastName}" />

                    <Label text="Title" />
                    <Text text="{Title}" />

                    <Label text="Team ID" />
                    <Text text="{TeamId}" />

                    <Label text="Email" />
                    <Text text="{Email}" />

                    <Label text="Phone" />
                    <Text text="{Phone}" />

                    <Label text="Birth Date" />
                    <Text text="{path: 'BirthDate', type: 'sap.ui.model.type.Date', formatOptions: { style: 'medium', UTC: true }}" />

                    <Label text="Start Date" />
                    <Text text="{path: 'StartDate', type: 'sap.ui.model.type.Date', formatOptions: { style: 'medium', UTC: true }}" />

                    <Label text="Status" />
                    <Text text="{Status}" />
                </f:SimpleForm>

                <layout:Splitter
                    id="employeeDetailSplitter"
                    height="600px"
                    class="sapUiSmallMarginTop">

                    <layout:contentAreas>
                        <VBox width="100%">
                            <layoutData>
                                <layout:SplitterLayoutData
                                    size="25%"
                                    resizable="true"
                                    minSize="220" />
                            </layoutData>

                            <Panel headerText="Employee Navigation" height="100%">
                                <Tree
                                    id="employeeTree"
                                    items="{nav>/nodes}"
                                    mode="SingleSelectMaster"
                                    selectionChange=".onTreeSelectionChange">

                                    <StandardTreeItem
                                        title="{nav>title}"
                                        icon="{nav>icon}" />
                                </Tree>
                            </Panel>
                        </VBox>

                        <VBox width="100%">
                            <layoutData>
                                <layout:SplitterLayoutData
                                    size="75%"
                                    resizable="true"
                                    minSize="450" />
                            </layoutData>

                            <Panel headerText="Details" height="100%">
                                <VBox
                                    id="detailHost"
                                    width="100%"
                                    fitContainer="true"
                                    class="sapUiSmallMargin">

                                    <MessageStrip
                                        text="Select a category from the left side."
                                        type="Information"
                                        showIcon="true" />
                                </VBox>
                            </Panel>
                        </VBox>
                    </layout:contentAreas>
                </layout:Splitter>
            </VBox>
        </content>
    </Page>
</mvc:View>