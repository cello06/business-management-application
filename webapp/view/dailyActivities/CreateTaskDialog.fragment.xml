<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog
    id="createTaskDialog"
    title="New Task"
    contentWidth="480px"
    draggable="true"
    resizable="true">

    <content>
      <VBox class="sapUiSmallMargin sapUiSmallMarginTop">

        <Label text="Title" required="true" class="sapUiTinyMarginBottom"/>
        <Input
          id="taskTitle"
          placeholder="Enter task title"
          width="100%"
          class="sapUiSmallMarginBottom"/>

        <Label text="Description" class="sapUiTinyMarginBottom"/>
        <TextArea
          id="taskDesc"
          placeholder="Enter description (optional)"
          rows="3"
          width="100%"
          class="sapUiSmallMarginBottom"/>

        <!-- Assignee row — visible only for leaders/admins -->
        <VBox id="taskAssigneeRow" visible="false" class="sapUiSmallMarginBottom">
          <Label text="Assignee" class="sapUiTinyMarginBottom"/>
          <ComboBox
            id="taskAssignee"
            width="100%"
            placeholder="Pick a team member (leave empty for Backlog)"
            showSecondaryValues="false"/>
        </VBox>

        <Label text="Status" class="sapUiTinyMarginBottom"/>
        <Select id="taskStatus" width="100%" class="sapUiSmallMarginBottom">
          <items>
            <core:Item key="BACKLOG"     text="Backlog (unassigned)"/>
            <core:Item key="TODO"        text="To Do"/>
            <core:Item key="IN_PROGRESS" text="In Progress"/>
            <core:Item key="TEST"        text="Test"/>
            <core:Item key="COMPLETED"   text="Completed"/>
          </items>
        </Select>

        <Label text="Priority" class="sapUiTinyMarginBottom"/>
        <Select id="taskPriority" width="100%" class="sapUiSmallMarginBottom">
          <items>
            <core:Item key="H" text="&#x1F534; High"/>
            <core:Item key="M" text="&#x1F7E1; Medium"/>
            <core:Item key="L" text="&#x1F7E2; Low"/>
          </items>
        </Select>

        <Label text="Due Date" class="sapUiTinyMarginBottom"/>
        <DatePicker
          id="taskDueDate"
          valueFormat="yyyy-MM-dd"
          displayFormat="dd.MM.yyyy"
          width="100%"
          class="sapUiSmallMarginBottom"/>

        <Label text="Project (optional)" class="sapUiTinyMarginBottom"/>
        <Select
          id="taskProject"
          width="100%"
          forceSelection="false"
          class="sapUiSmallMarginBottom"/>

        <Label text="Effort (MD)" class="sapUiTinyMarginBottom"/>
        <StepInput
          id="taskPoints"
          min="0"
          max="100"
          step="1"
          value="1"
          description="man-days"
          width="100%"/>

      </VBox>
    </content>

    <buttons>
      <Button text="Save" type="Emphasized" press="onSaveTask"/>
      <Button text="Cancel" press="onCancelTask"/>
    </buttons>

  </Dialog>
</core:FragmentDefinition>
