<mvc:View
  controllerName="hrproject.controller.CreateEmployee"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.ui.layout.form">

  <Page title="Create Employee" showNavButton="true" navButtonPress=".onNavBack">
    <content>
      <VBox class="sapUiSmallMargin">

        <f:SimpleForm
          editable="true"
          layout="ResponsiveGridLayout"
          title="New Employee">
          
        <Label text="TC ID" />
        <Input id="inpPersId" maxLength="11" type="Number" liveChange=".onPersIdLiveChange"/>

          <Label text="First Name" />
          <Input id="inpFirstName" />

          <Label text="Last Name" />
          <Input id="inpLastName" />

          <Label text="Title" />
          <Input id="inpTitle" />

          <Label text="Team ID" />
          <Input id="inpTeamId" editable="false" />

          <Label text="Email" />
          <Input id="inpEmail" type="Email" />

          <Label text="Phone" />
          <Input id="inpPhone" type="Tel" />

          <Label text="Birth Date" />
          <DatePicker id="inpBirthDate" valueFormat="yyyy-MM-dd" displayFormat="long" />

          <Label text="Gender" />
          <Select id="selGender">
            <core:Item key="" text="" />
            <core:Item key="M" text="Male" />
            <core:Item key="F" text="Female" />
            <core:Item key="O" text="Other" />
          </Select>

          <Label text="Start Date" />
          <DatePicker id="inpStartDate" valueFormat="yyyy-MM-dd" displayFormat="long" />

          <Label text="Status" />
          <Select id="selStatus">
            <core:Item key="ACTIVE" text="Active" />
            <core:Item key="INACTIVE" text="Inactive" />
          </Select>

        </f:SimpleForm>

        <HBox class="sapUiSmallMarginTop" justifyContent="End">
          <Button text="Save" type="Emphasized" press=".onSave" />
        </HBox>
      </VBox>
    </content>
  </Page>

</mvc:View>